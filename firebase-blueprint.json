{
  "entities": {
    "Search": {
      "title": "Search",
      "description": "A user's search history entry.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user who performed the search."
        },
        "category": {
          "type": "string",
          "description": "The selected category."
        },
        "budget": {
          "type": "string",
          "description": "The selected budget."
        },
        "needs": {
          "type": "array",
          "description": "The selected needs."
        },
        "details": {
          "type": "string",
          "description": "Additional details provided by the user."
        },
        "results": {
          "type": "object",
          "description": "The recommendation results."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the search was performed."
        }
      },
      "required": ["userId", "category", "budget", "needs", "results", "createdAt"]
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "description": "A product saved to the user's wishlist.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user."
        },
        "product": {
          "type": "object",
          "description": "The product details."
        },
        "savedAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the product was saved."
        }
      },
      "required": ["userId", "product", "savedAt"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback on a recommendation.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The UID of the user."
        },
        "searchId": {
          "type": "string",
          "description": "The ID of the search this feedback relates to."
        },
        "productName": {
          "type": "string",
          "description": "The name of the product."
        },
        "helpful": {
          "type": "boolean",
          "description": "Whether the recommendation was helpful."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the feedback was submitted."
        }
      },
      "required": ["userId", "searchId", "productName", "helpful", "createdAt"]
    },
    "Ad": {
      "title": "Ad",
      "description": "An advertisement entry.",
      "type": "object",
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the ad."
        },
        "image_url": {
          "type": "string",
          "description": "The URL of the ad image."
        },
        "target_url": {
          "type": "string",
          "description": "The destination URL when clicked."
        },
        "placement": {
          "type": "string",
          "enum": ["right_sidebar", "top_banner", "inline", "sponsored"],
          "description": "Where the ad is displayed."
        },
        "start_date": {
          "type": "string",
          "format": "date-time",
          "description": "When the ad starts showing."
        },
        "end_date": {
          "type": "string",
          "format": "date-time",
          "description": "When the ad stops showing."
        },
        "is_active": {
          "type": "boolean",
          "description": "Whether the ad is currently active."
        },
        "priority": {
          "type": "number",
          "description": "Optional priority for rotation."
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the ad was created."
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "When the ad was last updated."
        }
      },
      "required": ["title", "image_url", "target_url", "placement", "start_date", "end_date", "is_active", "created_at", "updated_at"]
    }
  },
  "firestore": {
    "/searches/{searchId}": {
      "schema": {
        "$ref": "#/entities/Search"
      },
      "description": "Stores user search history."
    },
    "/wishlist/{wishlistId}": {
      "schema": {
        "$ref": "#/entities/WishlistItem"
      },
      "description": "Stores user wishlisted products."
    },
    "/feedback/{feedbackId}": {
      "schema": {
        "$ref": "#/entities/Feedback"
      },
      "description": "Stores user feedback on recommendations."
    },
    "/ads/{adId}": {
      "schema": {
        "$ref": "#/entities/Ad"
      },
      "description": "Stores advertisement data."
    }
  }
}
